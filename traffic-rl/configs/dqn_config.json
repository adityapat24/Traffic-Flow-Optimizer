{
  "sumocfg_path": "sumo/sim.sumocfg",
  "sumo_binary": "sumo",
  "normalize_observations": true,

  "seed": 42,
  "num_episodes": 60,
  "max_steps_per_episode": 200,

  "gamma": 0.99,
  "learning_rate": 0.001,
  "batch_size": 64,
  "buffer_capacity": 10000,
  "warmup_steps": 200,

  "epsilon_start": 1.0,
  "epsilon_decay": 0.995,
  "epsilon_min": 0.05,

  "target_update_freq": 200,
  "hidden_dim": 128,

  "save_every": 10,
  "eval_episodes": 5,
  "use_cuda": false
}

